# ─── Google Sheets ───────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# ─── Anthropic Claude API ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── SMTP (zia@devtronics.co) ────────────────────────────────
SMTP_HOST=mail.devtronics.co
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=zia@devtronics.co
SMTP_PASS=your_email_password_here
FROM_NAME=Zia Arsalan
FROM_EMAIL=zia@devtronics.co

# ─── App ─────────────────────────────────────────────────────
PORT=8082

# ─── Upwork Job Monitor ──────────────────────────────────────
GOOGLE_JOBS_SHEET_ID=
UPWORK_JOBS_TAB=Upwork
CRON_INTERVAL=*/10 * * * *
UPWORK_CRON_ENABLED=false
UPWORK_KEYWORDS=GoHighLevel,GHL developer,SaaS development,AI integration developer,loyalty program developer,Next.js developer,React Node.js SaaS,white label SaaS
UPWORK_SOURCE=fixtures
APIFY_API_TOKEN=              # from apify.com → Settings → Integrations
APIFY_ACTOR_ID=neatrat/upwork-job-scraper
APIFY_MAX_RESULTS=25
UPWORK_AUTO_COVER=true        # true = monitor auto-generates cover letters; false = generate from the UI

# ─── Auth ────────────────────────────────────────────────────
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=change_me
JWT_SECRET=change_me_long_random_string

# ─── Outreach V2 (MongoDB + Queue) ───────────────────────────
# MongoDB Atlas (production target) — paste your Atlas SRV URI; local mongodb://localhost:27017/devtronics-outreach also works
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/devtronics-outreach
QUEUE_WORKER_ENABLED=false
SEND_MODE=warmup
