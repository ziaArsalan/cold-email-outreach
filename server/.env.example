# ─── Google Sheets ───────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# ─── Google Gemini API (ACTIVE AI provider) ───────────────────
# Used for outreach email intros (aiService) + Upwork cover letters (proposalService).
GEMINI_API_KEY=your_gemini_api_key_here
# Optional. Default: gemini-3-flash-preview. NOTE: gemini-2.5-* models are retired
# for new API keys. Web-search grounding is NOT used — it requires a billed plan
# (free tier returns 429), so prompts forbid inventing company facts.
# GEMINI_MODEL=gemini-3-flash-preview

# ─── Anthropic Claude API (INACTIVE — previous provider) ──────
# Only needed if you restore the commented-out Claude code in
# services/aiService.js + services/proposalService.js (that version used
# Claude's web_search to research each company).
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── SMTP (zia@devtronics.co) ────────────────────────────────
SMTP_HOST=mail.devtronics.co
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=zia@devtronics.co
SMTP_PASS=your_email_password_here
FROM_NAME=Zia Arsalan
FROM_EMAIL=zia@devtronics.co

# ─── App ─────────────────────────────────────────────────────
PORT=8082

# ─── Upwork Job Monitor ──────────────────────────────────────
GOOGLE_JOBS_SHEET_ID=
UPWORK_JOBS_TAB=Upwork
CRON_INTERVAL=*/10 * * * *
UPWORK_CRON_ENABLED=false
UPWORK_KEYWORDS=GoHighLevel,GHL developer,SaaS development,AI integration developer,loyalty program developer,Next.js developer,React Node.js SaaS,white label SaaS
UPWORK_SOURCE=fixtures
APIFY_API_TOKEN=              # from apify.com → Settings → Integrations
APIFY_ACTOR_ID=neatrat/upwork-job-scraper
APIFY_MAX_RESULTS=25
UPWORK_AUTO_COVER=true        # true = monitor auto-generates cover letters; false = generate from the UI

# ─── Auth ────────────────────────────────────────────────────
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=change_me
JWT_SECRET=change_me_long_random_string

# ─── Outreach V2 (MongoDB + Queue) ───────────────────────────
# MongoDB Atlas (production target) — paste your Atlas SRV URI; local mongodb://localhost:27017/devtronics-outreach also works
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/devtronics-outreach
# NOTE: The tunables below (QUEUE_WORKER_ENABLED, SEND_MODE, DELAY_*, QUEUE_MAX_RETRIES,
# WORKER_IDLE_MS, EMAIL_VERIFY_*) are now FALLBACK DEFAULTS. When the portal's
# "Outreach Settings" (Settings tab) has a stored value for a field, that value wins;
# these env vars only apply to fields the portal has never overridden.
QUEUE_WORKER_ENABLED=false
SEND_MODE=warmup
# Optional worker tuning overrides (defaults shown):
# DELAY_WARMUP_MIN_MS=240000
# DELAY_WARMUP_MAX_MS=480000
# DELAY_PROD_MIN_MS=120000
# DELAY_PROD_MAX_MS=300000
# QUEUE_MAX_RETRIES=3
# WORKER_IDLE_MS=30000
# FOLLOWUP_DELAY_UNIT_MS=86400000   # ms per follow-up "day" (shrink for testing)
# Optional pre-send email screening overrides (defaults shown — all 'true'):
# EMAIL_VERIFY_CHECK_MX=true
# EMAIL_VERIFY_BLOCK_DISPOSABLE=true
# EMAIL_VERIFY_BLOCK_ROLE_BASED=true
